{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "skipLibCheck": true,
    
    /* Allow extension-less imports */
    "allowImportingTsExtensions": true,
    "noEmit": true,

    /* Strictness & Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
     "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}
